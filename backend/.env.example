NODE_ENV=development
PORT=3001

JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bytechain
DB_SSL=false

FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3001

THROTTLE_TTL=60
THROTTLE_LIMIT=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=ByteChain Academy
SMTP_FROM_EMAIL=noreply@bytechain.academy

AVATAR_UPLOAD_PATH=uploads/avatars
